# ─── LLM（可选，无 Key 时系统降级为规则模式仍可完整跑通匹配）──
# OpenAI 兼容接口（DeepSeek / OpenAI / 其他兼容服务）
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# ─── 嵌入向量（可选，默认用内置本地嵌入）──
EMBED_API_BASE=
EMBED_API_KEY=
EMBED_MODEL=

# ─── 服务 ───
PORT=8787
JWT_SECRET=change-me-to-a-long-random-string-in-production
# 数据库文件路径
DB_PATH=./data/matchmate.db

# ─── 限流（每用户每小时 LLM 对话轮数）──
RATE_LIMIT_PER_HOUR=30

# ─── 隐私：对话保留天数，到期归档/清理 ───
CONVERSATION_RETENTION_DAYS=30

# ─── CORS（前端地址）──
WEB_ORIGIN=http://localhost:5173

# ─── Redis（可选，未配置时系统降级到内存模式，不持久化）──
# 留空 = 不启用 Redis（开发环境推荐留空，零依赖跑起来）
# 配置后启用：进程重启不丢数据 + 4 层记忆持久化 + 跨进程共享
REDIS_URL=
# 示例：REDIS_URL=redis://localhost:6379
# 示例：REDIS_URL=redis://:password@redis-host:6379/0

# ─── 增强系统开关（可选，默认全开）──
# 关闭后系统回退到原 Dazi 行为（不影响主功能）
ENHANCED_SYSTEM_ENABLED=true
# MBTI 模块开关（false = 不抽 MBTI 信号）
MBTI_ENABLED=true
# Cache-First LLM 开关（false = 走原始 llmClient.chatStream）
CACHE_LLM_ENABLED=true
# 自动压缩开关（false = 不触发 micro/auto compact）
COMPRESS_ENABLED=true
# 4 层记忆总线开关（false = 不写入 MemoryBus）
MEMORY_BUS_ENABLED=true
